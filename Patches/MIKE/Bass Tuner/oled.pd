#X obj 29 149 s oscOut;
#X text 560 -21 Drawing on Organelle OLED.;
#X text 559 92 The OLED is 128 x 64 pixels. Each one is on or off (0
or 1);
#X text 560 115 Point 0 \, 0 is top left of screen.;
#X text 560 138 The internal update rate is around 20 frames per second
\, so you shouldn't send commands (or groups of commands e.g. to draw
a frame) faster than 50 ms \, it will only eat CPU.;
#X msg 321 101 /oled/gShowInfoBar 3 0;
#X msg 305 125 /oled/gClear 3 1;
#X msg 116 641 /oled/gFlip 3;
#X text 559 1 The message format is: command \, screen number \, [x
\, y \, other stuff];
#X text 559 57 The x and y coordinates and other stuff is optional
depending on message.;
#X text 560 35 The screen number is always 3;
#X text 562 233 Line \, start x \, y \, end x \, y \, color (0 or 1)
;
#X text 563 252 Box \, x \, y \, width \, height \, color (0 or 1)
;
#X text 563 277 Print line \, x \, y \, size \, color \, stuff to print
;
#X text 580 296 4 font sizes available: 8 \, 16 \, 24 \, 32;
#X msg 807 387 /oled/gPrintln 3 0 10 16 1 Bigger;
