#N canvas 120 80 980 720 10;
#X text 30 15 PLAY multitrack synth pd~ split. Main patch keeps sequencing/voice allocation. Voices 1-4 go to pd~ A, voices 5-8 go to pd~ B. Each subprocess runs four synthvoice instances and receives synthparams messages.;
#X obj 55 55 inlet;
#X obj 410 650 outlet~;
#X obj 500 650 outlet~;
#X obj 250 545 pd~ -ninsig 0 -noutsig 2;
#X obj 585 545 pd~ -ninsig 0 -noutsig 2;
#X obj 55 105 route 1 2 3 4 5 6 7 8, f 104;
#X obj 55 150 list prepend synthnote 1;
#X obj 55 180 list trim;
