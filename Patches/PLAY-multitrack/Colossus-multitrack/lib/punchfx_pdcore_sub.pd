#X msg 35 75 \; pd dsp 1;
#X obj 70 140 adc~ 1 2;
#N canvas 380 180 480 310 fxcore 0;
#X obj 35 40 inlet~;
#X obj 115 40 inlet~;
#X obj 35 125 punchfx_core~;
#X obj 35 205 outlet~;
#X obj 115 205 outlet~;
#X obj 315 55 r pfxswitch;
#X obj 315 90 switch~;
#X obj 250 55 loadbang;
#X msg 250 90 0;
#X connect 0 0 2 0;
#X connect 1 0 2 1;
#X connect 2 0 3 0;
#X connect 2 1 4 0;
#X connect 5 0 6 0;
#X connect 7 0 8 0;
#X connect 8 0 6 0;
